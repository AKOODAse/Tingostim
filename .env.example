# Tingostim environment variables — copy to `.env` (gitignored) and fill in.
# All values here are optional; scripts/setup.sh will prompt interactively
# for anything missing.

# Database name used by Odoo and the React frontend (DEFAULT_DB in src/api.js).
# Override if you ran setup.sh with a non-default name.
# TINGOSTIM_DB=MNtory

# Skip the password prompts in scripts/setup.sh by pre-setting these.
# Leave blank to be prompted (recommended).
# TINGOSTIM_ADMIN_PASSWORD=
# TINGOSTIM_FACTORY_PASSWORD=

# Postgres credentials used by docker-compose.yml. Defaults are fine for dev;
# change for production deployments.
# POSTGRES_USER=odoo
# POSTGRES_PASSWORD=odoo
