<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="module_category_tingostim" model="ir.module.category">
            <field name="name">Tingostim</field>
            <field name="description">Tingostim B2B factory capacity sharing platform</field>
            <field name="sequence">20</field>
        </record>

        <record id="group_tingostim_factory_user" model="res.groups">
            <field name="name">Factory User</field>
            <field name="category_id" ref="module_category_tingostim"/>
            <field name="comment">A user belonging to a contracted factory. Reads all machines, requests rentals on other factories' idle machines, edits their own factory's machine metadata (not status).</field>
        </record>

        <record id="group_tingostim_platform_admin" model="res.groups">
            <field name="name">Platform Admin</field>
            <field name="category_id" ref="module_category_tingostim"/>
            <field name="implied_ids" eval="[(4, ref('group_tingostim_factory_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
            <field name="comment">Tingostim platform staff. Manages factories, users, and per-machine ingest tokens.</field>
        </record>

        <record id="rule_machine_read_all" model="ir.rule">
            <field name="name">Tingostim Machine: factory users read all</field>
            <field name="model_id" ref="model_tingostim_machine"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_tingostim_factory_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_machine_write_own_factory" model="ir.rule">
            <field name="name">Tingostim Machine: factory users edit only their own factory</field>
            <field name="model_id" ref="model_tingostim_machine"/>
            <field name="domain_force">[('factory_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('group_tingostim_factory_user'))]"/>
            <field name="perm_read" eval="False"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_machine_admin_all" model="ir.rule">
            <field name="name">Tingostim Machine: platform admin sees all</field>
            <field name="model_id" ref="model_tingostim_machine"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_tingostim_platform_admin'))]"/>
        </record>

        <record id="rule_machine_log_provider_only" model="ir.rule">
            <field name="name">Tingostim Machine Log: factory users see their own factory's logs</field>
            <field name="model_id" ref="model_tingostim_machine_log"/>
            <field name="domain_force">[('machine_id.factory_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('group_tingostim_factory_user'))]"/>
        </record>

        <record id="rule_machine_log_admin_all" model="ir.rule">
            <field name="name">Tingostim Machine Log: platform admin sees all</field>
            <field name="model_id" ref="model_tingostim_machine_log"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_tingostim_platform_admin'))]"/>
        </record>

        <record id="rule_rental_request_visible" model="ir.rule">
            <field name="name">Tingostim Rental Request: visible to requester or provider factory</field>
            <field name="model_id" ref="model_tingostim_rental_request"/>
            <field name="domain_force">['|', ('requester_partner_id', '=', user.partner_id.id), ('provider_partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('group_tingostim_factory_user'))]"/>
        </record>

        <record id="rule_rental_request_admin_all" model="ir.rule">
            <field name="name">Tingostim Rental Request: platform admin sees all</field>
            <field name="model_id" ref="model_tingostim_rental_request"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_tingostim_platform_admin'))]"/>
        </record>

    </data>
</odoo>
