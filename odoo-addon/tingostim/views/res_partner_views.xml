<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_form_inherit_tingostim" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.tingostim</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Factory" name="tingostim_factory" invisible="not is_factory">
                    <group>
                        <group>
                            <field name="is_factory"/>
                            <field name="factory_location"/>
                            <field name="founded_year"/>
                            <field name="employee_count"/>
                        </group>
                        <group>
                            <field name="specialty"/>
                            <field name="factory_color" placeholder="#E83828"/>
                            <field name="machine_count"/>
                        </group>
                    </group>
                    <group string="Bio">
                        <field name="factory_bio" nolabel="1"/>
                    </group>
                    <group string="Machines">
                        <field name="machine_ids" nolabel="1" readonly="1">
                            <list>
                                <field name="name"/>
                                <field name="machine_type"/>
                                <field name="status"/>
                                <field name="current_capacity" widget="progressbar"/>
                                <field name="hourly_rate"/>
                            </list>
                        </field>
                    </group>
                </page>
            </xpath>
            <xpath expr="//field[@name='vat']" position="before">
                <field name="is_factory"/>
            </xpath>
        </field>
    </record>

    <record id="action_factory_partners" model="ir.actions.act_window">
        <field name="name">Factories</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('is_factory', '=', True)]</field>
        <field name="context">{'default_is_factory': True, 'default_company_type': 'company'}</field>
    </record>

</odoo>
