<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_rental_request_list" model="ir.ui.view">
        <field name="name">tingostim.rental_request.list</field>
        <field name="model">tingostim.rental_request</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'pending'" decoration-success="state == 'accepted'" decoration-muted="state in ('rejected', 'cancelled')">
                <field name="create_date"/>
                <field name="requester_partner_id"/>
                <field name="machine_id"/>
                <field name="provider_partner_id"/>
                <field name="requested_date"/>
                <field name="duration_hours"/>
                <field name="estimated_cost"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_rental_request_form" model="ir.ui.view">
        <field name="name">tingostim.rental_request.form</field>
        <field name="model">tingostim.rental_request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_accept" type="object" string="Accept" class="oe_highlight" invisible="state != 'pending'"/>
                    <button name="action_reject" type="object" string="Reject" invisible="state != 'pending'"/>
                    <button name="action_complete" type="object" string="Mark Completed" invisible="state != 'accepted'"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="state in ('completed', 'rejected', 'cancelled')"/>
                    <field name="state" widget="statusbar" statusbar_visible="pending,accepted,completed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="machine_id"/>
                            <field name="provider_partner_id" readonly="1"/>
                            <field name="requester_partner_id"/>
                        </group>
                        <group>
                            <field name="requested_date"/>
                            <field name="duration_hours"/>
                            <field name="estimated_cost"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_rental_request_search" model="ir.ui.view">
        <field name="name">tingostim.rental_request.search</field>
        <field name="model">tingostim.rental_request</field>
        <field name="arch" type="xml">
            <search>
                <field name="machine_id"/>
                <field name="requester_partner_id"/>
                <field name="provider_partner_id"/>
                <filter string="Pending" name="filter_pending" domain="[('state', '=', 'pending')]"/>
                <filter string="Accepted" name="filter_accepted" domain="[('state', '=', 'accepted')]"/>
                <filter string="Completed" name="filter_completed" domain="[('state', '=', 'completed')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Provider" name="group_provider" context="{'group_by': 'provider_partner_id'}"/>
                    <filter string="Requester" name="group_requester" context="{'group_by': 'requester_partner_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_rental_requests" model="ir.actions.act_window">
        <field name="name">Rental Requests</field>
        <field name="res_model">tingostim.rental_request</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
