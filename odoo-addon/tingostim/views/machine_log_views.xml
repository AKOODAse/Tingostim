<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_machine_log_list" model="ir.ui.view">
        <field name="name">tingostim.machine_log.list</field>
        <field name="model">tingostim.machine_log</field>
        <field name="arch" type="xml">
            <list create="false" edit="false">
                <field name="log_time"/>
                <field name="machine_id"/>
                <field name="status"/>
                <field name="capacity" widget="progressbar"/>
            </list>
        </field>
    </record>

    <record id="view_machine_log_form" model="ir.ui.view">
        <field name="name">tingostim.machine_log.form</field>
        <field name="model">tingostim.machine_log</field>
        <field name="arch" type="xml">
            <form create="false" edit="false">
                <sheet>
                    <group>
                        <field name="machine_id"/>
                        <field name="log_time"/>
                        <field name="status"/>
                        <field name="capacity"/>
                    </group>
                    <group string="Raw Payload">
                        <field name="raw_payload" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_machine_logs" model="ir.actions.act_window">
        <field name="name">Telemetry Logs</field>
        <field name="res_model">tingostim.machine_log</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
