            <field name="factory_color">#E83828</field>
            <field name="specialty">CNC &amp; Precision Machining</field>
            <field name="jobs_completed">342</field>
            <field name="revenue_total">48500</field>
            <field name="uptime_pct">96.5</field>
            <field name="rating">4.8</field>
            <field name="streak_days">14</field>
        </record>

